# ── Server ──
PORT=3050
NODE_ENV=development

# ── QuickNode Marketplace Auth ──
# Basic auth credentials for PUDD lifecycle endpoints (provision/update/deactivate/deprovision)
QN_BASIC_AUTH_USERNAME=
QN_BASIC_AUTH_PASSWORD=

# ── Database ──
# Path to SQLite database file. Use ":memory:" for testing.
DB_PATH=./data/sentinel.db

# ── EVM (Flashbots) ──
# Required for EVM bundle submission, simulation, and private transactions
EVM_RPC_URL=

# 32-byte hex private key for Flashbots relay authentication (optional)
# Used to build reputation with the Flashbots relay. Without it, bundles are submitted anonymously.
# Example: ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
FLASHBOTS_AUTH_KEY=

# ── Solana (Jito) ──
# Required for Solana bundle submission and status checks
SOLANA_RPC_URL=
JITO_BLOCK_ENGINE_URL=

# ── Oracle Registry (optional) ──
# Ethereum RPC URL for resolving Chainlink Feed Registry oracle addresses
# Used by Guard to dynamically discover oracle feeds for price manipulation detection
ORACLE_REGISTRY_RPC_URL=
