{
  "name": "Fabrknt DeFi Toolkit",
  "slug": "fabrknt-defi-toolkit",
  "description": "Chain-agnostic transaction security analysis detecting 17 patterns across Solana and EVM. Pre-execution simulation sandbox, execution plan builders (DCA, rebalance, grid trading), and MEV-protected bundle management via Jito (Solana) and Flashbots/MEV-Share (EVM).",
  "version": "0.2.0",
  "author": "Fabrknt",
  "category": "developer-tools",
  "support": {
    "email": "support@fabrknt.com",
    "url": "https://fabrknt.com/support"
  },
  "repository": "https://github.com/fabrknt/sentinel",
  "chains": [
    {
      "id": "solana",
      "name": "Solana"
    },
    {
      "id": "ethereum",
      "name": "Ethereum"
    }
  ],
  "healthcheck": "/healthcheck",
  "authentication": "basic",
  "provisioning": {
    "provision": "POST /provision",
    "update": "PUT /update",
    "deactivate": "DELETE /deactivate_endpoint",
    "deprovision": "DELETE /deprovision"
  },
  "plans": [
    {
      "id": "starter",
      "name": "Starter",
      "price": 0,
      "description": "Transaction security analysis (17 patterns), pre-execution simulation, and execution plan builders.",
      "rate_limit": {
        "requests_per_minute": 100
      },
      "features": [
        "Transaction security analysis (8 Solana + 9 EVM patterns)",
        "Pre-execution simulation sandbox (EVM + Solana)",
        "Honeypot detection via simulation",
        "Bytecode-level opcode analysis",
        "Batch payout builder",
        "Recurring payment scheduler",
        "Token vesting scheduler",
        "Grid trading planner",
        "DCA strategy planner",
        "Portfolio rebalance planner"
      ]
    },
    {
      "id": "pro",
      "name": "Pro",
      "price": 49,
      "description": "All Starter features plus MEV-protected bundle management for Solana (Jito) and EVM (Flashbots/MEV-Share).",
      "rate_limit": {
        "requests_per_minute": 200
      },
      "features": [
        "All Starter features",
        "Jito bundle submission (Solana)",
        "Flashbots bundle submission (EVM)",
        "MEV-Share private order flow (EVM)",
        "Flashbots Protect single-tx privacy (EVM)",
        "Bundle simulation (Flashbots eth_callBundle)",
        "Bundle status tracking (Jito + Flashbots)",
        "Dynamic tip calculation (Jito)",
        "Priority support"
      ]
    }
  ],
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/guard/analyze",
      "description": "Analyze a transaction for security patterns with optional simulation (Solana or EVM)",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/guard/analyze-raw",
      "description": "Analyze raw transaction bytes for pattern detection only",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/pattern/batch-payout",
      "description": "Build a batch payout execution plan",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/pattern/recurring-payment",
      "description": "Build a recurring payment schedule",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/pattern/vesting",
      "description": "Build a token vesting schedule",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/pattern/grid-trading",
      "description": "Build a grid trading plan",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/pattern/dca",
      "description": "Build a DCA strategy plan",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/pattern/rebalance",
      "description": "Build a portfolio rebalance plan",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/bundle/submit",
      "description": "Submit a bundle (Jito for Solana, Flashbots/MEV-Share for EVM)",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/bundle/simulate",
      "description": "Simulate an EVM bundle via Flashbots eth_callBundle",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/bundle/private-tx",
      "description": "Send a single private EVM transaction via Flashbots Protect",
      "plan": "pro"
    },
    {
      "method": "GET",
      "path": "/v1/bundle/status/:bundleId",
      "description": "Get bundle status (Jito or Flashbots)",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/bundle/tip",
      "description": "Get recommended Jito tip amount and tip account",
      "plan": "pro"
    }
  ]
}
